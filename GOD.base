summaries:
  Unique: values.unique().length
  Filled: values.filter(!value.isType("null")).length
views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder.contains("docs")
        - '!file.folder.startsWith("templates")'
        - '!file.folder.startsWith("docs/assets")'
        - '!file.folder.startsWith("docs/stylesheets")'
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - file.mtime
      - wp_url
    sort:
      - property: file.name
        direction: ASC
    summaries:
      file.name: Filled
    columnSize:
      note.wp_url: 752
  - type: table
    name: Products
    filters:
      and:
        - file.inFolder("docs/ec/products")
    order:
      - file.name
      - wp_url
    sort: []
    summaries:
      file.name: Filled
